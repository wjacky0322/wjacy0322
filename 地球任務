<!DOCTYPE html>
<html lang="zh-TW" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ING-001 進貨食材 AI 自動分級智慧看板</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#ecfdf5',
                            100: '#d1fae5',
                            500: '#10b981',
                            600: '#059669',
                            900: '#064e3b',
                        }
                    }
                }
            }
        }
    </script>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans+TC:wght@300;400;500;700;900&display=swap');
        body { font-family: 'Plus Jakarta Sans', 'Noto Sans TC', sans-serif; -webkit-tap-highlight-color: transparent; }
        
        .glass-panel {
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }

        .pulse-ring {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            animation: pulse-ring-anim 2s infinite cubic-bezier(0.66, 0, 0, 1);
        }
        @keyframes pulse-ring-anim {
            to { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
        }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen pb-20 md:pb-10 selection:bg-emerald-500 selection:text-slate-950">

    <!-- Sticky Header -->
    <header class="border-b border-slate-800/80 bg-slate-950/90 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center gap-2">
            <div class="flex items-center space-x-2.5">
                <div class="p-2 bg-gradient-to-br from-emerald-400 to-emerald-600 rounded-xl text-slate-950 font-black shadow-lg shadow-emerald-500/20">
                    <i data-lucide="scan-face" class="w-5 h-5 md:w-6 md:h-6"></i>
                </div>
                <div>
                    <div class="flex items-center gap-1.5">
                        <span class="px-1.5 py-0.5 rounded text-[9px] md:text-[10px] font-extrabold bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 font-mono">ING-001</span>
                        <h1 class="text-sm md:text-lg font-black tracking-tight text-white" id="txtTitle">進貨食材自動分級看板</h1>
                    </div>
                    <p class="text-[10px] md:text-xs text-slate-400 hidden sm:block" id="txtSubTitle">食品產業 AI 菁英班 · 地球賽道 · Ares-05 號艙</p>
                </div>
            </div>

            <!-- Header Controls: Language Selector & Status -->
            <div class="flex items-center gap-2">
                <!-- Multi-language Selector -->
                <div class="relative">
                    <select id="langSelect" onchange="changeLanguage(this.value)" class="bg-slate-900 border border-slate-700 text-xs text-emerald-400 font-bold rounded-lg px-2 py-1.5 focus:outline-none focus:ring-1 focus:ring-emerald-400 cursor-pointer">
                        <option value="zh-TW">繁體中文</option>
                        <option value="en">English</option>
                        <option value="ja">日本語</option>
                        <option value="vi">Tiếng Việt</option>
                    </select>
                </div>

                <button onclick="loadDefaultData()" class="px-2.5 py-1.5 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold text-xs rounded-lg transition shadow-md shadow-emerald-500/20 flex items-center gap-1">
                    <i data-lucide="rotate-cw" class="w-3.5 h-3.5"></i> 
                    <span class="hidden md:inline" id="btnReload">重新載入 360 筆</span>
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 md:py-6 space-y-4 md:space-y-6">

        <!-- 1. High Risk Alert Banner (NG Warning System) -->
        <div id="ngAlertBanner" class="hidden glass-panel rounded-xl p-3 md:p-4 border-l-4 border-rose-500 bg-rose-950/20 animate__animated animate__fadeInDown">
            <div class="flex items-start justify-between gap-3">
                <div class="flex items-start gap-2.5">
                    <i data-lucide="alert-octagon" class="w-5 h-5 text-rose-500 flex-shrink-0 mt-0.5"></i>
                    <div>
                        <h3 class="text-xs md:text-sm font-bold text-rose-400" id="txtNgAlertTitle">高風險退貨警示！發現不合格 NG 進貨食材</h3>
                        <p class="text-[11px] md:text-xs text-slate-300 mt-0.5" id="txtNgAlertDesc">檢測到變質/損傷食材批次，請相關人員處理退貨：</p>
                        <div id="ngAlertList" class="flex flex-wrap gap-1.5 mt-2"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Owner Hidden Requirement: Instant 1-Second Search Zone -->
        <section class="glass-panel rounded-2xl p-4 md:p-5 border-l-4 border-amber-400 relative overflow-hidden">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
                <div class="space-y-1">
                    <div class="flex items-center gap-2">
                        <span class="bg-amber-400/20 text-amber-300 text-[10px] md:text-xs px-2 py-0.5 rounded-full font-bold border border-amber-400/30 flex items-center gap-1">
                            <i data-lucide="shield-alert" class="w-3 h-3"></i> <span id="txtAuditTag">稽核專用 1 秒定位</span>
                        </span>
                        <span class="text-[10px] md:text-xs text-slate-400" id="txtAuditSub">解決單筆紀錄缺失痛點</span>
                    </div>
                    <h2 class="text-sm md:text-base font-bold text-white" id="txtAuditTitle">毫秒級全欄位精準檢索模組</h2>
                </div>

                <!-- Live Search Box -->
                <div class="w-full md:w-80 relative">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3 top-2.5 text-slate-400"></i>
                    <input type="text" id="quickSearchInput" onkeyup="instantSearch()" 
                           placeholder="輸入 ID (如 ING-102)、食材或負責人..." 
                           class="w-full pl-9 pr-8 py-2 bg-slate-900 border border-slate-700 rounded-xl text-xs text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400">
                    <button onclick="resetSearch()" class="absolute right-2.5 top-2 text-slate-400 hover:text-white">
                        <i data-lucide="x-circle" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            <!-- Single Result Card -->
            <div id="searchResultCard" class="hidden mt-3 pt-3 border-t border-slate-800 grid grid-cols-2 sm:grid-cols-6 gap-2 text-xs">
                <div class="bg-slate-900/90 p-2 rounded-lg border border-slate-800"><span class="text-slate-500 block text-[9px]">ID</span><span id="resId" class="font-mono font-bold text-amber-400">-</span></div>
                <div class="bg-slate-900/90 p-2 rounded-lg border border-slate-800"><span class="text-slate-500 block text-[9px]" id="txtDateCol">日期</span><span id="resDate" class="font-mono text-white">-</span></div>
                <div class="bg-slate-900/90 p-2 rounded-lg border border-slate-800"><span class="text-slate-500 block text-[9px]" id="txtItemCol">食材</span><span id="resItem" class="font-bold text-emerald-400">-</span></div>
                <div class="bg-slate-900/90 p-2 rounded-lg border border-slate-800"><span class="text-slate-500 block text-[9px]" id="txtGradeCol">分級</span><span id="resGrade" class="font-bold">-</span></div>
                <div class="bg-slate-900/90 p-2 rounded-lg border border-slate-800"><span class="text-slate-500 block text-[9px]" id="txtWeightCol">重量</span><span id="resWeight" class="font-mono text-white">-</span></div>
                <div class="bg-slate-900/90 p-2 rounded-lg border border-slate-800"><span class="text-slate-500 block text-[9px]" id="txtOwnerCol">負責人</span><span id="resOwner" class="font-semibold text-white">-</span></div>
            </div>
        </section>

        <!-- 3. KPI Cards & Weight Analytics -->
        <section class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
            <div class="glass-panel p-3.5 rounded-xl border border-slate-800 flex flex-col justify-between">
                <div class="text-[10px] md:text-xs text-slate-400" id="txtTotalTitle">有效批次總數</div>
                <div class="text-xl md:text-2xl font-black text-white font-mono mt-1" id="kpiTotal">0</div>
                <div class="text-[9px] text-slate-500 mt-1 flex justify-between">
                    <span id="txtTotalWeightTitle">總重量:</span> <span id="kpiTotalWeight" class="font-mono text-emerald-400">0 kg</span>
                </div>
            </div>

            <div class="glass-panel p-3.5 rounded-xl border border-emerald-500/20 bg-emerald-950/10 flex flex-col justify-between">
                <div class="text-[10px] md:text-xs text-emerald-400" id="txtGradeSTitle">特級 (S級)</div>
                <div class="text-xl md:text-2xl font-black text-eme
